# T.O.N.Y. — Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env or .env.local — they are listed in .gitignore

# ======================
# Supabase (from https://app.supabase.com/project/_/settings/api)
# ======================
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-side only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ======================
# Mux API credentials (from https://dashboard.mux.com/settings/access-tokens)
# ======================
MUX_TOKEN_ID=your-mux-api-token-id
MUX_TOKEN_SECRET=your-mux-api-token-secret

# ======================
# Mux JWT signing key (from https://dashboard.mux.com/settings/signing-keys)
# Create with: curl -X POST https://api.mux.com/system/v1/signing-keys -u "$MUX_TOKEN_ID:$MUX_TOKEN_SECRET"
# ======================
MUX_SIGNING_KEY_ID=your-signing-key-id
MUX_SIGNING_PRIVATE_KEY=base64-encoded-rsa-private-key

# ======================
# Mux Playback Restrictions — see docs/mux-setup.md for curl commands
# ======================
# Website restriction (domain-locked, allow_no_referrer: false)
MUX_PLAYBACK_RESTRICTION_ID=restriction-id-for-website
# Roku restriction (allow_no_referrer: true, for FAST streaming)
MUX_PLAYBACK_RESTRICTION_ROKU_ID=restriction-id-for-roku

# ======================
# FAST Advertising (VAST 3.0 ad tag URL from your ad network)
# Leave empty to disable ads in the MRSS feed
# ======================
VAST_TAG_URL=

# ======================
# Square Payments (from https://developer.squareup.com/apps)
# ======================
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
# Webhook signature key (from Square Dashboard > Webhooks)
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key
# Environment: 'sandbox' for testing, 'production' for live
SQUARE_ENVIRONMENT=sandbox

# ======================
# AWS S3 (for download-link presigned URLs)
# (from https://console.aws.amazon.com/iam/home#/users)
# ======================
VITE_AWS_ACCESS_KEY_ID=your-aws-access-key-id
VITE_AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
VITE_AWS_REGION=us-east-1
VITE_S3_BUCKET=tony-media-assets

# ======================
# Cloudinary (from https://cloudinary.com/console)
# Image transformations and CDN delivery
# ======================
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_API_KEY=your-api-key
VITE_CLOUDINARY_API_SECRET=your-api-secret

# ======================
# CDN
# ======================
VITE_CDN_URL=https://cdn.tonyseries.com
VITE_CDN_VERSION=v1

# ======================
# Application
# ======================
VITE_APP_URL=http://localhost:3000
# Price in cents (e.g., 499 = $4.99)
VITE_FILM_PRICE_CENTS=499
NODE_ENV=development

# ======================
# Feature Toggles
# ======================
# Set to 'true' to enable Press Kit section (disabled until assets are ready)
VITE_ENABLE_PRESS_KIT=false

# ======================
# Gemini API (from https://aistudio.google.com/app/apikey)
# ======================
GEMINI_API_KEY=your-gemini-api-key
