<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />

  <children>
    <!-- Full black background -->
    <Rectangle width="1920" height="1080" color="#020B13" />

    <!-- Hero poster — full width -->
    <Poster
      id="heroPoster"
      width="1920"
      height="800"
      uri="https://image.mux.com/GCrZV02lhiXHvASjK24E00JFBruFw4uJKT7RAtBRvCdko/thumbnail.jpg?width=1920&amp;height=800"
      translation="[0, 0]"
    />

    <!-- Dark gradient at bottom of poster -->
    <Rectangle width="1920" height="300" color="#020B13" opacity="0.85" translation="[0, 550]" />

    <!-- App logo -->
    <Poster id="appLogo" uri="pkg:/images/icon-hd.png" width="90" height="90" translation="[1780, 30]" />

    <!-- Title -->
    <Label text="T.O.N.Y." font="font:LargeBoldSystemFont" color="#DAAB2D" translation="[80, 620]" />
    <Label text="TOP OF NEW YORK" font="font:MediumBoldSystemFont" color="#FFFFFF" translation="[80, 670]" />

    <!-- Gold divider -->
    <Rectangle width="120" height="3" color="#DAAB2D" translation="[80, 715]" />

    <!-- Episode info -->
    <Label text="Season 1, Episode 1  •  TV-MA" font="font:SmallSystemFont" color="#DAAB2D" translation="[80, 735]" />
    <Label text="A Bronx Crime Saga" font="font:SmallSystemFont" color="#AAAAAA" translation="[80, 765]" />

    <!-- BIG play prompt -->
    <Label
      id="playPrompt"
      text="▶  PRESS OK TO PLAY"
      font="font:LargeBoldSystemFont"
      color="#DAAB2D"
      translation="[680, 900]"
    />

    <!-- Status -->
    <Label id="statusLabel" text="" font="font:SmallSystemFont" color="#666666" translation="[80, 1040]" />

    <!-- Video player (hidden until playing) -->
    <Video
      id="videoPlayer"
      width="1920"
      height="1080"
      translation="[0, 0]"
      visible="false"
      enableUI="true"
    />

    <!-- Buffering spinner (hidden) -->
    <BusySpinner id="spinner" translation="[930, 480]" visible="false" />
  </children>
</component>
