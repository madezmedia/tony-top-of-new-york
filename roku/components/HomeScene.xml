<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />

  <!-- Deep linking interface (required for certification) -->
  <interface>
    <field id="deepLinkContentId" type="string" onChange="onDeepLink" />
    <field id="deepLinkMediaType" type="string" />
  </interface>

  <children>
    <!-- Full background — 1280x720 for HD Roku -->
    <Rectangle id="background" width="1280" height="720" color="#020B13" />

    <!-- Hero poster — sized for 720p -->
    <Poster
      id="heroPoster"
      width="1280"
      height="500"
      uri="https://image.mux.com/GCrZV02lhiXHvASjK24E00JFBruFw4uJKT7RAtBRvCdko/thumbnail.jpg?width=1280&amp;height=500"
      translation="[0, 0]"
    />

    <!-- Dark gradient at bottom of poster -->
    <Rectangle width="1280" height="200" color="#020B13" opacity="0.85" translation="[0, 350]" />

    <!-- App logo top-right -->
    <Poster id="appLogo" uri="pkg:/images/icon-hd.png" width="60" height="60" translation="[1190, 20]" />

    <!-- Title -->
    <Label text="T.O.N.Y." font="font:LargeBoldSystemFont" color="#DAAB2D" translation="[50, 400]" />
    <Label text="TOP OF NEW YORK" font="font:MediumBoldSystemFont" color="#FFFFFF" translation="[50, 445]" />

    <!-- Gold divider -->
    <Rectangle width="80" height="3" color="#DAAB2D" translation="[50, 480]" />

    <!-- Episode info -->
    <Label text="Season 1, Episode 1  •  TV-MA" font="font:SmallSystemFont" color="#DAAB2D" translation="[50, 495]" />
    <Label id="descriptionLabel" text="A Bronx Crime Saga" font="font:SmallSystemFont" color="#AAAAAA" translation="[50, 520]" width="600" />

    <!-- Play prompt -->
    <Label
      id="playPrompt"
      text="▶  PRESS OK TO PLAY"
      font="font:MediumBoldSystemFont"
      color="#DAAB2D"
      translation="[440, 620]"
    />

    <!-- Status -->
    <Label id="statusLabel" text="" font="font:SmallSystemFont" color="#666666" translation="[50, 690]" />

    <!-- Video player (hidden until playing) — 1280x720 -->
    <Video
      id="videoPlayer"
      width="1280"
      height="720"
      translation="[0, 0]"
      visible="false"
      enableUI="true"
      enableTrickPlay="true"
    />

    <!-- Buffering spinner -->
    <BusySpinner id="spinner" translation="[610, 330]" visible="false" />

    <!-- Exit Confirmation Dialog (required for back button on home screen) -->
    <Dialog
      id="exitDialog"
      title="Exit T.O.N.Y."
      message="Are you sure you want to exit?"
      visible="false"
    />
  </children>
</component>
