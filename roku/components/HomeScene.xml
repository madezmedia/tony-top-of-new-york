<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />

  <!-- Deep linking interface -->
  <interface>
    <field id="deepLinkContentId" type="string" onChange="onDeepLink" />
    <field id="deepLinkMediaType" type="string" />
  </interface>

  <children>
    <!-- Full background -->
    <Rectangle id="background" width="1280" height="720" color="#030E17" />

    <!-- Roku Pay ChannelStore -->
    <ChannelStore id="channelStore" />

    <!-- ============ HERO & CINEMATIC OVERLAYS ============ -->

    <!-- Background trailer video (auto-plays muted like Netflix) -->
    <Video
      id="bgTrailer"
      width="1280"
      height="450"
      translation="[0, 0]"
      visible="false"
      enableUI="false"
      enableTrickPlay="false"
      mute="true"
      loop="true"
    />

    <!-- Hero poster fallback (shown until trailer loads) -->
    <Poster
      id="heroPoster"
      width="1280"
      height="450"
      uri="https://image.mux.com/GCrZV02lhiXHvASjK24E00JFBruFw4uJKT7RAtBRvCdko/thumbnail.jpg?width=1280&amp;height=500"
      translation="[0, 0]"
    />

    <!-- THE CINEMATIC OVERLAYS (Safe version using standard nodes) -->
    <!-- Left-side vertical wash for readability -->
    <Rectangle width="640" height="450" translation="[0, 0]" color="#030E17" opacity="0.6" />
    
    <!-- Bottom horizontal wash for RowList transition -->
    <Rectangle width="1280" height="300" translation="[0, 150]" color="#030E17" opacity="0.95" />

    <!-- Top bar gradient/wash for branding readability -->
    <Rectangle width="1280" height="100" translation="[0, 0]" color="#030E17" opacity="0.4" />

    <!-- ============ QUADRANT 1: TOP LEFT (BRANDING) ============ -->
    <Group id="brandingGroup" translation="[60, 40]">
      <Label id="heroTitle" text="T.O.N.Y." font="font:LargeBoldSystemFont" color="#DAAB2D" />
      <Label id="heroSubtitle" text="TOP OF NEW YORK" font="font:SmallBoldSystemFont" color="#FFFFFF" translation="[2, 40]" />
      <Rectangle width="60" height="3" color="#DAAB2D" translation="[2, 65]" />
    </Group>

    <!-- ============ QUADRANT 2: TOP RIGHT (USER/ACCOUNT) ============ -->
    <Group id="userGroup" translation="[1080, 40]">
      <Rectangle id="accountBtnBg" width="140" height="44" color="#E61025" translation="[0, 0]" />
      <Label id="accountBtnText" text="SIGN IN" font="font:SmallBoldSystemFont" color="#FFFFFF" 
        width="140" horizAlign="center" translation="[0, 10]" />
    </Group>

    <!-- ============ QUADRANT 3: MIDDLE LEFT (FOCUS DETAIL) ============ -->
    <Group id="detailPanel" translation="[60, 160]" visible="true">
      <Label id="detailTitle" text="CONCRETE JUNGLE" font="font:LargeBoldSystemFont" color="#FFFFFF" width="800" />
      
      <Group translation="[0, 50]">
        <!-- Rating badge -->
        <Rectangle width="70" height="26" color="#E61025" />
        <Label id="detailRating" text="TV-MA" font="font:SmallestBoldSystemFont" color="#FFFFFF"
          width="70" horizAlign="center" translation="[0, 4]" />
        
        <Label id="detailMeta" text="S1:E1 • 2h 12m • 2026" font="font:SmallBoldSystemFont" color="#DAAB2D" translation="[85, 2]" />
      </Group>

      <Label id="detailDescription"
        text="Sample description for the cinematic experience."
        font="font:SmallSystemFont" color="#CCCCCC"
        translation="[0, 95]" width="650" maxLines="3" wrap="true" lineSpacing="4"
      />

      <Label id="playHint" text="PRESS OK TO WATCH" font="font:SmallestBoldSystemFont" color="#DAAB2D" translation="[0, 180]" />
    </Group>

    <!-- ============ QUADRANT 4: BOTTOM (CONTENT) ============ -->
    <RowList
      id="contentRowList"
      translation="[60, 470]"
      itemComponentName="ContentItem"
      numRows="4"
      itemSize="[1220, 240]"
      rowItemSize="[[280, 200]]"
      rowItemSpacing="[[20, 0]]"
      itemSpacing="[0, 20]"
      showRowLabel="[true]"
      rowLabelOffset="[[0, 10]]"
      rowLabelFont="font:SmallBoldSystemFont"
      rowLabelColor="#DAAB2D"
      rowFocusAnimationStyle="fixedFocusWrap"
      vertFocusAnimationStyle="fixedFocus"
    />

    <!-- ============ FULL VIDEO PLAYER ============ -->
    <Video
      id="videoPlayer"
      width="1280"
      height="720"
      translation="[0, 0]"
      visible="false"
      enableUI="true"
      enableTrickPlay="true"
    />

    <!-- Buffering/Loading Elements -->
    <BusySpinner id="spinner" translation="[610, 330]" visible="false" />
    <Label id="statusLabel" text="" font="font:SmallSystemFont" color="#DAAB2D" translation="[60, 680]" />

    <!-- Overlays -->
    <Dialog id="exitDialog" title="Exit T.O.N.Y." message="Are you sure you want to exit?" visible="false" />
    <AccountScene id="accountScene" visible="false" />

  </children>
</component>
