<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />

  <!-- Deep linking interface (required for certification) -->
  <interface>
    <field id="deepLinkContentId" type="string" onChange="onDeepLink" />
    <field id="deepLinkMediaType" type="string" />
  </interface>

  <children>
    <!-- Full background -->
    <Rectangle id="background" width="1280" height="720" color="#020B13" />

    <!-- ============ HERO SECTION ============ -->
    <!-- Hero poster (dynamic resolution via Mux thumbnail API) -->
    <Poster
      id="heroPoster"
      width="1280"
      height="400"
      uri="https://image.mux.com/GCrZV02lhiXHvASjK24E00JFBruFw4uJKT7RAtBRvCdko/thumbnail.jpg?width=1280&amp;height=400"
      translation="[0, 0]"
    />

    <!-- Hero gradient overlay -->
    <Rectangle width="1280" height="250" color="#020B13" opacity="0.9" translation="[0, 250]" />

    <!-- App logo top-right -->
    <Poster id="appLogo" uri="pkg:/images/icon-hd.png" width="50" height="50" translation="[1200, 15]" />

    <!-- Hero Title & Info -->
    <Label id="heroTitle" text="T.O.N.Y." font="font:LargeBoldSystemFont" color="#DAAB2D" translation="[50, 300]" />
    <Label id="heroSubtitle" text="TOP OF NEW YORK" font="font:MediumBoldSystemFont" color="#FFFFFF" translation="[50, 340]" />
    <Rectangle width="60" height="2" color="#DAAB2D" translation="[50, 375]" />
    <Label id="heroMeta" text="Season 1  •  TV-MA  •  Crime Drama" font="font:SmallSystemFont" color="#DAAB2D" translation="[50, 385]" />
    <Label id="heroDescription" text="In the unforgiving streets of the Bronx, power is earned and survival comes at a cost." font="font:SmallSystemFont" color="#AAAAAA" translation="[50, 408]" width="500" />

    <!-- ============ CONTENT ROWS ============ -->
    <RowList
      id="contentRowList"
      translation="[50, 445]"
      itemComponentName="ContentItem"
      numRows="4"
      itemSize="[1180, 190]"
      rowItemSize="[[240, 180]]"
      rowItemSpacing="[[15, 0]]"
      itemSpacing="[0, 10]"
      showRowLabel="[true]"
      rowLabelOffset="[[0, 8]]"
      rowLabelFont="font:SmallBoldSystemFont"
      rowLabelColor="#DAAB2D"
      rowFocusAnimationStyle="fixedFocusWrap"
      vertFocusAnimationStyle="fixedFocus"
      focusXOffset="[0]"
    />

    <!-- ============ VIDEO PLAYER ============ -->
    <Video
      id="videoPlayer"
      width="1280"
      height="720"
      translation="[0, 0]"
      visible="false"
      enableUI="true"
      enableTrickPlay="true"
    />

    <!-- Buffering spinner -->
    <BusySpinner id="spinner" translation="[610, 330]" visible="false" />

    <!-- Status label (for errors) -->
    <Label id="statusLabel" text="" font="font:SmallSystemFont" color="#FF4444" translation="[50, 690]" />

    <!-- Exit Confirmation Dialog -->
    <Dialog
      id="exitDialog"
      title="Exit T.O.N.Y."
      message="Are you sure you want to exit?"
      visible="false"
    />
  </children>
</component>
