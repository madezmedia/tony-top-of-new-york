<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />

  <!-- Deep linking interface -->
  <interface>
    <field id="deepLinkContentId" type="string" onChange="onDeepLink" />
    <field id="deepLinkMediaType" type="string" />
  </interface>

  <children>
    <!-- Full background -->
    <Rectangle id="background" width="1280" height="720" color="#020B13" />

    <!-- Roku Pay ChannelStore -->
    <ChannelStore id="channelStore" />

    <!-- ============ HERO & OVERLAYS ============ -->

    <!-- Top-Right Quadrant Trailer -->
    <Video
      id="bgTrailer"
      width="600"
      height="338"
      translation="[620, 40]"
      visible="false"
      enableUI="false"
      enableTrickPlay="false"
      mute="true"
      loop="true"
    />

    <Poster
      id="heroPoster"
      width="600"
      height="338"
      uri="https://image.mux.com/GCrZV02lhiXHvASjK24E00JFBruFw4uJKT7RAtBRvCdko/thumbnail.jpg?width=600&amp;height=338"
      translation="[620, 40]"
    />

    <!-- Subtle overlays for readability -->
    <Rectangle width="1280" height="150" translation="[0, 310]" color="#020B13" opacity="0.6" />

    <!-- ============ QUADRANT 1: TOP LEFT (BRANDING) ============ -->
    <Group translation="[60, 40]">
      <!-- 1.5x scaled Brand Logo -->
      <Poster id="heroLogo" uri="pkg:/images/logo.png" width="450" height="150" loadDisplayMode="limitSize" />
      <Label id="heroSubtitle" text="A MICHAEL STEVEN-PAUL CRIME SERIES" font="font:SmallBoldSystemFont" color="#00D7FF" translation="[10, 140]" />
      <Rectangle width="120" height="2" color="#00D7FF" translation="[10, 168]" />
    </Group>

    <!-- ============ QUADRANT 2: TOP RIGHT (USER/ACCOUNT) ============ -->
    <Group translation="[1080, 40]">
      <Rectangle id="accountBtnBg" width="140" height="40" color="#E61025" translation="[0, 0]" />
      <Label id="accountBtnText" text="SIGN IN" font="font:SmallestBoldSystemFont" color="#FFFFFF" 
        width="140" horizAlign="center" translation="[0, 10]" />
    </Group>

    <!-- ============ QUADRANT 3: MIDDLE LEFT (FOCUS DETAIL) ============ -->
    <Group id="detailPanel" translation="[60, 240]">
      <Label id="detailTitle" text="CONCRETE JUNGLE" font="font:MediumBoldSystemFont" color="#FFFFFF" width="800" />
      
      <Group translation="[0, 40]">
        <Rectangle width="60" height="22" color="#E61025" />
        <Label id="detailRating" text="TV-MA" font="font:SmallestBoldSystemFont" color="#FFFFFF"
          width="60" horizAlign="center" translation="[0, 2]" />
        
        <Label id="detailMeta" text="S1:E1 • 2h 12m" font="font:SmallestBoldSystemFont" color="#00D7FF" translation="[75, 2]" />
      </Group>

      <Label id="detailDescription"
        text=""
        font="font:SmallSystemFont" color="#CCCCCC"
        translation="[0, 80]" width="550" maxLines="2" wrap="true"
      />

      <Label id="playHint" text="OK to Watch  •  ★ Trailer" font="font:SmallestSystemFont" color="#00D7FF" translation="[0, 130]" />
    </Group>

    <!-- ============ QUADRANT 4: BOTTOM (CONTENT) ============ -->
    <RowList
      id="contentRowList"
      translation="[60, 440]"
      itemComponentName="ContentItem"
      numRows="4"
      itemSize="[1200, 240]"
      rowItemSize="[[280, 200]]"
      rowItemSpacing="[[20, 0]]"
      itemSpacing="[0, 20]"
      showRowLabel="[true]"
      rowLabelOffset="[[0, 10]]"
      rowLabelFont="font:SmallBoldSystemFont"
      rowLabelColor="#00D7FF"
      rowFocusAnimationStyle="fixedFocusWrap"
      vertFocusAnimationStyle="fixedFocus"
    />

    <!-- ============ FULL VIDEO PLAYER ============ -->
    <Video
      id="videoPlayer"
      width="1280"
      height="720"
      translation="[0, 0]"
      visible="false"
      enableUI="true"
      enableTrickPlay="true"
    />

    <!-- Buffering/Loading Elements -->
    <BusySpinner id="spinner" translation="[610, 330]" visible="false" />
    <Label id="statusLabel" text="" font="font:SmallSystemFont" color="#00D7FF" translation="[60, 680]" />

    <!-- Overlays -->
    <Dialog id="exitDialog" title="Exit T.O.N.Y." message="Are you sure you want to exit?" visible="false" />
    <AccountScene id="accountScene" visible="false" />

  </children>
</component>
