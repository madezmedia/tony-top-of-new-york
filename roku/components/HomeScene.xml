<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />

  <children>
    <!-- Background -->
    <Rectangle
      id="background"
      width="1920"
      height="1080"
      color="#020B13"
    />

    <!-- Hero thumbnail background -->
    <Poster
      id="heroImage"
      width="1920"
      height="540"
      translation="[0, 0]"
    />

    <!-- Gradient overlays -->
    <Rectangle width="1920" height="120" color="#020B13" opacity="0.8" translation="[0, 0]" />
    <Rectangle width="1920" height="200" color="#020B13" opacity="0.9" translation="[0, 380]" />

    <!-- App logo in top-right corner -->
    <Poster id="appLogo" uri="pkg:/images/icon-hd.png" width="90" height="90" translation="[1780, 20]" />

    <!-- T.O.N.Y. Branding -->
    <Label id="showTitle" text="T.O.N.Y." font="font:LargeBoldSystemFont" color="#DAAB2D" translation="[80, 30]" />
    <Label id="showSubtitle" text="TOP OF NEW YORK" font="font:MediumBoldSystemFont" color="#FFFFFF" translation="[80, 80]" />
    <Rectangle width="120" height="3" color="#DAAB2D" translation="[80, 125]" />

    <!-- Hero episode info -->
    <Label id="heroEpisodeTitle" text="" font="font:MediumBoldSystemFont" color="#FFFFFF" width="900" translation="[80, 150]" />
    <Label id="heroEpisodeMeta" text="" font="font:SmallSystemFont" color="#DAAB2D" translation="[80, 195]" />
    <Label id="heroEpisodeDesc" text="" font="font:SmallSystemFont" color="#AAAAAA" width="800" maxLines="3" wrap="true" translation="[80, 230]" />
    <Label id="playPrompt" text="▶  Press OK to Play" font="font:SmallBoldSystemFont" color="#DAAB2D" translation="[80, 320]" visible="false" />

    <!-- EPISODES section -->
    <Label id="gridTitle" text="EPISODES" font="font:SmallBoldSystemFont" color="#DAAB2D" translation="[80, 540]" />
    <Rectangle width="1760" height="1" color="#333333" translation="[80, 570]" />

    <!-- Episode Grid with focusable explicitly set -->
    <MarkupGrid
      id="episodeGrid"
      translation="[80, 590]"
      itemSize="[320, 230]"
      itemSpacing="[20, 20]"
      numColumns="5"
      numRows="2"
      drawFocusFeedback="true"
      vertFocusAnimationStyle="fixedFocusWrap"
      focusBitmapBlendColor="#DAAB2D"
      focusable="true"
      itemComponentName="EpisodeItem"
    />

    <!-- Loading indicator -->
    <BusySpinner id="loadingSpinner" translation="[930, 480]" visible="true" />

    <!-- Status label -->
    <Label id="statusLabel" text="Loading..." font="font:SmallSystemFont" color="#666666" translation="[80, 1030]" />
  </children>
</component>
