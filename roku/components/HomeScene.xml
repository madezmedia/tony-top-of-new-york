<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />

  <!-- Deep linking interface -->
  <interface>
    <field id="deepLinkContentId" type="string" onChange="onDeepLink" />
    <field id="deepLinkMediaType" type="string" />
  </interface>

  <children>
    <!-- Full background -->
    <Rectangle id="background" width="1280" height="720" color="#020B13" />

    <!-- Roku Pay ChannelStore -->
    <ChannelStore id="channelStore" />

    <!-- ============ HERO & OVERLAYS ============ -->

    <Video
      id="bgTrailer"
      width="1280"
      height="450"
      translation="[0, 0]"
      visible="false"
      enableUI="false"
      enableTrickPlay="false"
      mute="true"
      loop="true"
    />

    <Poster
      id="heroPoster"
      width="1280"
      height="450"
      uri="https://image.mux.com/GCrZV02lhiXHvASjK24E00JFBruFw4uJKT7RAtBRvCdko/thumbnail.jpg?width=1280&amp;height=500"
      translation="[0, 0]"
    />

    <!-- Subtle overlays for readability -->
    <Rectangle width="1280" height="200" translation="[0, 250]" color="#020B13" opacity="0.8" />
    <Rectangle width="500" height="450" translation="[0, 0]" color="#020B13" opacity="0.4" />

    <!-- ============ QUADRANT 1: TOP LEFT (BRANDING) ============ -->
    <Group translation="[60, 40]">
      <Label id="heroTitle" text="T.O.N.Y." font="font:LargeBoldSystemFont" color="#DAAB2D" />
      <Label id="heroSubtitle" text="TOP OF NEW YORK" font="font:SmallBoldSystemFont" color="#FFFFFF" translation="[0, 40]" />
      <Rectangle width="100" height="2" color="#DAAB2D" translation="[0, 65]" />
    </Group>

    <!-- ============ QUADRANT 2: TOP RIGHT (USER/ACCOUNT) ============ -->
    <Group translation="[1080, 40]">
      <Rectangle id="accountBtnBg" width="140" height="40" color="#E61025" translation="[0, 0]" />
      <Label id="accountBtnText" text="SIGN IN" font="font:SmallestBoldSystemFont" color="#FFFFFF" 
        width="140" horizAlign="center" translation="[0, 10]" />
    </Group>

    <!-- ============ QUADRANT 3: MIDDLE LEFT (FOCUS DETAIL) ============ -->
    <Group id="detailPanel" translation="[60, 160]">
      <Label id="detailTitle" text="CONCRETE JUNGLE" font="font:MediumBoldSystemFont" color="#FFFFFF" width="800" />
      
      <Group translation="[0, 40]">
        <Rectangle width="60" height="22" color="#E61025" />
        <Label id="detailRating" text="TV-MA" font="font:SmallestBoldSystemFont" color="#FFFFFF"
          width="60" horizAlign="center" translation="[0, 2]" />
        
        <Label id="detailMeta" text="S1:E1 • 2h 12m" font="font:SmallestBoldSystemFont" color="#DAAB2D" translation="[75, 2]" />
      </Group>

      <Label id="detailDescription"
        text=""
        font="font:SmallSystemFont" color="#AAAAAA"
        translation="[0, 80]" width="600" maxLines="3" wrap="true"
      />

      <Label id="playHint" text="OK to Watch  •  ★ Trailer" font="font:SmallestSystemFont" color="#555555" translation="[0, 145]" />
    </Group>

    <!-- ============ QUADRANT 4: BOTTOM (CONTENT) ============ -->
    <RowList
      id="contentRowList"
      translation="[60, 460]"
      itemComponentName="ContentItem"
      numRows="4"
      itemSize="[1200, 220]"
      rowItemSize="[[260, 180]]"
      rowItemSpacing="[[15, 0]]"
      itemSpacing="[0, 15]"
      showRowLabel="[true]"
      rowLabelOffset="[[0, 10]]"
      rowLabelFont="font:SmallBoldSystemFont"
      rowLabelColor="#DAAB2D"
      rowFocusAnimationStyle="fixedFocusWrap"
      vertFocusAnimationStyle="fixedFocus"
    />

    <!-- ============ FULL VIDEO PLAYER ============ -->
    <Video
      id="videoPlayer"
      width="1280"
      height="720"
      translation="[0, 0]"
      visible="false"
      enableUI="true"
      enableTrickPlay="true"
    />

    <!-- Buffering/Loading Elements -->
    <BusySpinner id="spinner" translation="[610, 330]" visible="false" />
    <Label id="statusLabel" text="" font="font:SmallSystemFont" color="#DAAB2D" translation="[60, 680]" />

    <!-- Overlays -->
    <Dialog id="exitDialog" title="Exit T.O.N.Y." message="Are you sure you want to exit?" visible="false" />
    <AccountScene id="accountScene" visible="false" />

  </children>
</component>
