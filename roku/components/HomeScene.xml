<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />

  <!-- Deep linking interface -->
  <interface>
    <field id="deepLinkContentId" type="string" onChange="onDeepLink" />
    <field id="deepLinkMediaType" type="string" />
  </interface>

  <children>
    <!-- Full background -->
    <Rectangle id="background" width="1280" height="720" color="#020B13" />

    <!-- ============ HERO SECTION ============ -->
    <Poster
      id="heroPoster"
      width="1280"
      height="400"
      uri="https://image.mux.com/GCrZV02lhiXHvASjK24E00JFBruFw4uJKT7RAtBRvCdko/thumbnail.jpg?width=1280&amp;height=400"
      translation="[0, 0]"
    />

    <!-- Hero gradients (bottom ~50% of hero area) -->
    <Rectangle width="1280" height="180" color="#020B13" opacity="0.9" translation="[0, 280]" />
    <Rectangle width="500" height="250" color="#020B13" opacity="0.6" translation="[0, 0]" />

    <!-- App logo -->
    <Poster id="appLogo" uri="pkg:/images/icon-focus-hd.png" width="50" height="38" translation="[1200, 15]" />

    <!-- Hero branding -->
    <Label id="heroTitle" text="T.O.N.Y." font="font:LargeBoldSystemFont" color="#DAAB2D" translation="[50, 20]" />
    <Label id="heroSubtitle" text="TOP OF NEW YORK" font="font:SmallBoldSystemFont" color="#FFFFFF" translation="[52, 60]" />
    <Rectangle width="50" height="2" color="#DAAB2D" translation="[52, 82]" />
    <Label id="heroMeta" text="Season 1  •  TV-MA  •  Crime Drama" font="font:SmallestSystemFont" color="#AAAAAA" translation="[52, 90]" />

    <!-- ============ DETAIL PANEL (updates on focus) ============ -->
    <Group id="detailPanel" translation="[50, 110]" visible="true">
      <!-- Detail title -->
      <Label id="detailTitle" text="S1:E1 — Concrete Jungle" font="font:MediumBoldSystemFont" color="#FFFFFF" translation="[0, 0]" width="700" />

      <!-- Rating badge -->
      <Rectangle width="50" height="20" color="#E61025" opacity="0.9" translation="[0, 35]" />
      <Label id="detailRating" text="TV-MA" font="font:SmallestBoldSystemFont" color="#FFFFFF"
        width="50" horizAlign="center" translation="[0, 37]" />

      <!-- Meta info (duration, etc) -->
      <Label id="detailMeta" text="S1:E1 • 45 min • TV-MA" font="font:SmallestSystemFont" color="#DAAB2D" translation="[58, 37]" />

      <!-- Episode description -->
      <Label id="detailDescription"
        text="Michael Cortez returns to the Bronx after years away, only to find the neighborhood he left behind has changed."
        font="font:SmallSystemFont" color="#AAAAAA"
        translation="[0, 62]" width="580" maxLines="3" wrap="true"
      />

      <!-- Play/Info hint -->
      <Label text="OK to Play  •  ★ Info" font="font:SmallestSystemFont" color="#555555" translation="[0, 120]" />
    </Group>

    <!-- ============ CONTENT ROWS ============ -->
    <RowList
      id="contentRowList"
      translation="[50, 455]"
      itemComponentName="ContentItem"
      numRows="4"
      itemSize="[1180, 190]"
      rowItemSize="[[240, 180]]"
      rowItemSpacing="[[15, 0]]"
      itemSpacing="[0, 10]"
      showRowLabel="[true]"
      rowLabelOffset="[[0, 8]]"
      rowLabelFont="font:SmallBoldSystemFont"
      rowLabelColor="#DAAB2D"
      rowFocusAnimationStyle="fixedFocusWrap"
      vertFocusAnimationStyle="fixedFocus"
      focusXOffset="[0]"
    />

    <!-- ============ VIDEO PLAYER ============ -->
    <Video
      id="videoPlayer"
      width="1280"
      height="720"
      translation="[0, 0]"
      visible="false"
      enableUI="true"
      enableTrickPlay="true"
    />

    <!-- Buffering spinner -->
    <BusySpinner id="spinner" translation="[610, 330]" visible="false" />

    <!-- Status / toast message -->
    <Label id="statusLabel" text="" font="font:SmallSystemFont" color="#DAAB2D" translation="[50, 690]" />

    <!-- Exit Dialog -->
    <Dialog
      id="exitDialog"
      title="Exit T.O.N.Y."
      message="Are you sure you want to exit?"
      visible="false"
    />
  </children>
</component>
