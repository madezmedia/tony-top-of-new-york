<?xml version="1.0" encoding="utf-8" ?>
<!-- AccountScene.xml - Device Linking Screen -->
<component name="AccountScene" extends="Rectangle" focusable="true">
  <script type="text/brightscript" uri="pkg:/components/AccountScene.brs" />

  <interface>
    <field id="authCompleted" type="bool" value="false" />
    <field id="isLoggedIn" type="bool" value="false" />
    <field id="logoutRequested" type="bool" value="false" />
  </interface>

  <!-- The task that polls the Vercel API -->
  <children>
    <AuthTask id="authTask" control="STOP" />

    <!-- Background -->
    <Rectangle id="background" width="1280" height="720" color="#030E17" />
    <Poster id="heroPoster" width="1280" height="720" uri="pkg:/images/splash-hd.png" opacity="0.1" />

    <!-- Activation UI (Shown when NOT logged in) -->
    <Group id="contentGroup" translation="[340, 120]" visible="true">
      <!-- Heading -->
      <Label text="ACTIVATE YOUR TV" font="font:LargeBoldSystemFont" color="#E61025" width="600" horizAlign="center" />
      <Rectangle width="100" height="3" color="#E61025" translation="[250, 50]" />

      <!-- High-level instruction -->
      <Label text="Link this device to your Top of New York account to unlock premium episodes and exclusive content." 
             font="font:MediumSystemFont" color="#FFFFFF" 
             translation="[0, 85]" width="600" horizAlign="center" wrap="true" lineSpacing="4" />
      
      <!-- Actionable step -->
      <Label text="1. Visit topofnewyork.com/activate on your phone&#10;2. Enter the 6-character code shown below:" 
             font="font:SmallBoldSystemFont" color="#AAAAAA" 
             translation="[0, 180]" width="600" horizAlign="center" wrap="true" lineSpacing="6" />

      <!-- The Code Display - Polished -->
      <Rectangle id="codeBg" width="380" height="120" color="#051521" translation="[110, 240]" />
      <Rectangle width="380" height="120" color="#E61025" opacity="0.2" translation="[110, 240]" />
      
      <Label id="codeLabel" text="GENERATING..." font="font:MediumBoldSystemFont" color="#FFFFFF" 
             translation="[110, 275]" width="380" horizAlign="center" />

      <!-- Spinner -->
      <BusySpinner id="spinner" translation="[275, 380]" visible="true" />

      <!-- Status/Error -->
      <Label id="statusLabel" text="Establishing secure connection..." font="font:SmallBoldSystemFont" color="#E61025" 
             translation="[0, 430]" width="600" horizAlign="center" />

      <!-- Footer Info -->
      <Label text="Press BACK to cancel and return to browsing." font="font:SmallestSystemFont" color="#445566" 
             translation="[0, 520]" width="600" horizAlign="center" />

      <!-- Legal & Privacy Button - Fixed UI -->
      <Rectangle id="legalBtnBg" width="220" height="40" color="#051521" translation="[190, 560]" opacity="0.6" />
      <Label id="legalBtnText" text="PRIVACY &amp; LEGAL" font="font:SmallestBoldSystemFont" color="#AAAAAA" 
             width="220" horizAlign="center" translation="[190, 570]" />
    </Group>

    <!-- Logged-in Account UI (Shown when logged in) -->
    <Group id="loggedInGroup" translation="[340, 120]" visible="false">
      <!-- Heading -->
      <Label text="MY ACCOUNT" font="font:LargeBoldSystemFont" color="#E61025" width="600" horizAlign="center" />
      <Rectangle width="100" height="3" color="#E61025" translation="[250, 50]" />

      <Label text="Your device is successfully linked to your Top of New York account." 
             font="font:MediumSystemFont" color="#FFFFFF" 
             translation="[0, 100]" width="600" horizAlign="center" wrap="true" />

      <Label text="Unlock premium episodes, trailers, and behind-the-scenes content across all your devices." 
             font="font:SmallSystemFont" color="#AAAAAA" 
             translation="[0, 180]" width="600" horizAlign="center" wrap="true" />

      <!-- Account Info Area -->
      <Rectangle width="400" height="100" color="#051521" translation="[100, 280]" />
      <Label text="Account Status:" font="font:SmallBoldSystemFont" color="#AAAAAA" translation="[120, 300]" />
      <Label text="Premium Access Active" font="font:SmallBoldSystemFont" color="#4ADE80" translation="[120, 330]" />

      <!-- Logout Button - Professional Look -->
      <Rectangle id="logoutBtnBg" width="300" height="60" color="#E61025" translation="[150, 450]" opacity="1.0" />
      <Label text="LOG OUT" font="font:MediumBoldSystemFont" color="#FFFFFF" 
             width="300" horizAlign="center" translation="[150, 465]" />
      
      <Label text="Press BACK to return to the catalog." font="font:SmallestSystemFont" color="#445566" 
             translation="[0, 540]" width="600" horizAlign="center" />
    </Group>

    <!-- The actual Legal Scene overlay -->
    <LegalScene id="legalScene" visible="false" />
  </children>
</component>
