  <children>
    <Rectangle id="background" width="1280" height="720" color="#020B13" />
    <Poster id="heroPoster" width="1280" height="720" uri="pkg:/images/splash-hd.png" opacity="0.10" />

    <Group id="contentGroup" translation="[140, 100]">
