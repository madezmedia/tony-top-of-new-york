             translation="[0, 80]" width="1000" wrap="true" lineSpacing="10" />
             
      <!-- Buttons -->
      <Rectangle id="backBtnBg" width="200" height="50" color="#E61025" translation="[0, 500]" />
      <Label id="backBtnText" text="Go Back" font="font:SmallBoldSystemFont" color="#FFFFFF" 
             width="200" horizAlign="center" translation="[0, 510]" />

    </Group>
  </children>
</component>
