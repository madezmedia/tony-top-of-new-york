<?xml version="1.0" encoding="utf-8" ?>
<component name="AuthTask" extends="Task">
  <interface>
    <!-- Inputs -->
    <field id="deviceId" type="string" />
    <field id="command" type="string" /> <!-- "generate" or "poll" -->
    
    <!-- Outputs -->
    <field id="code" type="string" />
    <field id="token" type="string" />
    <field id="status" type="string" /> <!-- "pending", "linked", "expired", "error" -->
    <field id="errorMessage" type="string" />
  </interface>

  <script type="text/brightscript" uri="pkg:/components/AuthTask.brs" />
</component>
